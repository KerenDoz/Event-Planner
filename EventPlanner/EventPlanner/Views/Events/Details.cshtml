@model EventPlanner.Models.Events.EventDetailsViewModel
@{
    ViewData["Title"] = "Event Details";
}

<h1>@Model.Title</h1>

<p class="text-muted">
    @Model.StartDate.ToString("yyyy-MM-dd HH:mm") → @Model.EndDate.ToString("yyyy-MM-dd HH:mm")
</p>

<p><strong>Category:</strong> @Model.CategoryName</p>
<p><strong>Location:</strong> @Model.City — @Model.LocationName
    @if (!string.IsNullOrWhiteSpace(Model.Address))
    {
        <span>(@Model.Address)</span>
    }
</p>
<p><strong>Capacity:</strong> @Model.Capacity</p>
<p><strong>Public:</strong> @(Model.IsPublic ? "Yes" : "No")</p>

<hr />
<p>@Model.Description</p>

<hr />
<h3>Comments</h3>

<hr />
<h3 class="mt-4">Rating</h3>

<p>
    <strong>Average rating:</strong>
    @Model.AverageRating.ToString("0.0") / 5
    (@Model.RatingsCount vote@(Model.RatingsCount == 1 ? "" : "s"))
</p>

<p><strong>Participants:</strong> @Model.TicketsCount</p>

@if (User.Identity?.IsAuthenticated == true)
{
    if (!Model.IsJoined)
    {
        <form asp-controller="Tickets" asp-action="Join" method="post">
            <input type="hidden" name="eventId" value="@Model.Id" />
            <button class="btn btn-success">Join Event</button>
        </form>
    }
    else
    {
        <form asp-controller="Tickets" asp-action="Leave" method="post">
            <input type="hidden" name="eventId" value="@Model.Id" />
            <button class="btn btn-danger">Leave Event</button>
        </form>
    }
}

@if (User.Identity?.IsAuthenticated == true)
{
    <form id="ratingForm" asp-action="Rate" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="eventId" value="@Model.Id" />
        <input type="hidden" name="value" id="ratingValue" value="@Model.UserRating" />

        <div id="rating">
            @for (int i = 1; i <= 5; i++)
            {
                <span class="star" data-value="@i" style="cursor:pointer; font-size:1.5rem;">
                    ★
                </span>
            }
        </div>

        @*<button type="submit" class="btn btn-warning">Save Rating</button>*@
    </form>

    @if (Model.UserRating.HasValue)
    {
        <p class="text-muted">Your rating: @Model.UserRating / 5</p>
    }
}
else
{
    <p class="text-muted">Please sign in to rate this event.</p>
}

@if (User.Identity?.IsAuthenticated == true)
{
    <form asp-action="AddComment" method="post" class="mb-3">
        <input type="hidden" name="eventId" value="@Model.Id" />

        <textarea name="Content" class="form-control mb-2" rows="3" placeholder="Write a comment..."></textarea>

        <button type="submit" class="btn btn-primary">Post</button>
    </form>
}
else
{
    <p><a asp-controller="Account" asp-action="Login">Login</a> to comment.</p>
}

@if (Model.Comments.Any())
{
    @foreach (var c in Model.Comments)
    {
        <div class="border rounded p-2 mb-2 bg-light">
            <strong>@c.UserName</strong>
            <small class="text-muted float-end">
                @c.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
            </small>
            <div>@c.Content</div>
        </div>
    }
}
else
{
    <p class="text-muted">No comments yet.</p>
}

@if (Model.IsOwner)
{
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
}
<a class="btn btn-secondary" asp-action="Index">Back</a>

<style>
    .star {
        color: lightgray;
        cursor: pointer;
        transition: color 0.2s;
    }

    .star.selected {
        color: gold;
    }
</style>

<script>
    const stars = document.querySelectorAll('#rating .star');
    const ratingValue = document.getElementById('ratingValue');
    const form = document.getElementById('ratingForm');

    function highlight(val) {
        stars.forEach(s => {
            const v = parseInt(s.getAttribute('data-value'));
            s.style.color = v <= val ? '#fbbf24' : '#d1d5db';
        });
    }

    stars.forEach(star => {
        star.addEventListener('click', () => {
            const val = parseInt(star.getAttribute('data-value'));
            ratingValue.value = val;
            highlight(val);

            // 🔥 AUTO SUBMIT
            form.submit();
        });
    });

    // initial highlight
    highlight(parseInt(ratingValue.value) || 0);
</script>

