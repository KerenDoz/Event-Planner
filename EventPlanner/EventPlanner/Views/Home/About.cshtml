@{
    ViewData["Title"] = "About";
}

<div class="text-center mb-4">
    <h1 class="display-5">About EventPlanner</h1>
    <p class="lead text-muted">
        ASP.NET Core MVC web application for creating, managing, and exploring events.
    </p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                <h4 class="mb-3">📌 Current Project Overview</h4>
                <p>
                    EventPlanner is a course project developed for <strong>SoftUni ASP.NET Fundamentals</strong>.
                    The application allows registered users to browse upcoming events, create their own events,
                    manage personal profile data, and interact with events through comments, ratings, and
                    joining/leaving.
                </p>

                <hr />

                <h4 class="mb-3">✨ Current Features</h4>
                <div class="row">
                    <div class="col-md-6">
                        <ul>
                            <li>User registration and login</li>
                            <li>Separate username and email</li>
                            <li>Account management</li>
                            <li>Change username, email, and password</li>
                            <li>Create, edit, and delete events</li>
                            <li>Public and private events</li>
                            <li>My Events page for event owners</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul>
                            <li>Join and leave events</li>
                            <li>Event comments</li>
                            <li>Event rating system</li>
                            <li>Categories and locations management</li>
                            <li>Administrator panel for users and content</li>
                            <li>Custom error pages for 400, 404, and 500</li>
                            <li>Unit tests for key application logic</li>
                        </ul>
                    </div>
                </div>

                <hr />

                <h4 class="mb-3">🛠 Technologies</h4>
                <ul>
                    <li>ASP.NET Core MVC (.NET 8)</li>
                    <li>Entity Framework Core</li>
                    <li>ASP.NET Core Identity</li>
                    <li>SQL Server</li>
                    <li>Bootstrap</li>
                    <li>HTML, CSS, and Razor Views</li>
                </ul>

                <hr />

                <h4 class="mb-3">🎯 Academic Goal</h4>
                <p class="mb-0">
                    The current version of the project focuses on demonstrating authentication, authorization,
                    CRUD operations, validation, database integration, cleaner UI structure, and practical MVC
                    architecture
                    in a complete event management application.
                </p>
            </div>
        </div>
    </div>
</div>
